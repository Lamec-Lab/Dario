% ---------------------------------------------------------------
% ARABIC SECTIONS (APPENDIX USE) --------------------------------
\newlength{\myAppendixLen} % New length
\newlength{\resultlen}
\newcommand{\asection}[2]{% 
  \expandafter\ifcsname c@asectioncounter@#1\endcsname
  \else % Counter already exists, do nothing
    \newcounter{asectioncounter@#1} 
  \fi % Creates the counter if it does not exist
  \settowidth{\myAppendixLen}{#1} % Add the horizontal length of #1
  \setlength{\resultlen}{1.3\dimexpr\myAppendixLen} % Correct mylen
  \stepcounter{asectioncounter@#1} % Increments the counter
  \setcounter{section}{\value{asectioncounter@#1}}
  \renewcommand{\thesection}{#1.\arabic{section}} 
  \setcounter{equation}{0}%
  \section*{\thesection\quad #2}%
  \addcontentsline{toc}{section}{\protect\numberline{\thesection}\hspace{-\the\resultlen}#2}%
}
